<?xml version="1.0" encoding="UTF-8"?>
<!--
	Standalone WiX installer template for the Vengi thumbnail handler shell extension.
	Processed by CMake configure_file() to fill in product name, DLL filename, etc.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
	<Product Id="*" Name="@WIX_PRODUCT_NAME@" Language="1033" Version="@WIX_VERSION@"
	         Manufacturer="vengi" UpgradeCode="@WIX_UPGRADE_GUID@">
		<Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine"
		         Platform="x64" Description="@WIX_DESCRIPTION@"
		         Comments="Provides thumbnail previews for voxel file formats in Windows Explorer" />
		<MajorUpgrade DowngradeErrorMessage="A newer version of @WIX_PRODUCT_NAME@ is already installed." />
		<MediaTemplate EmbedCab="yes" />

		<Directory Id="TARGETDIR" Name="SourceDir">
			<Directory Id="ProgramFiles64Folder">
				<Directory Id="INSTALLDIR" Name="@WIX_PRODUCT_NAME@">
					<Component Id="ThumbnailerDLL" Guid="*" Win64="yes">
						<File Id="@WIX_DLL_ID@" Source="$(var.SourceDir)\@WIX_DLL_FILENAME@" KeyPath="yes" />
					</Component>
					<Component Id="ThumbnailerCOM" Guid="*" Win64="yes">
						<RegistryKey Root="HKCR" Key="CLSID\{CD1F0EA0-283C-4D90-A41D-DEBD9207D91F}" ForceDeleteOnUninstall="yes">
							<RegistryValue Type="string" Value="Vengi thumbnailer" KeyPath="yes" />
							<RegistryKey Key="InprocServer32">
								<RegistryValue Type="string" Value="[#@WIX_DLL_ID@]" />
								<RegistryValue Type="string" Name="ThreadingModel" Value="Both" />
							</RegistryKey>
						</RegistryKey>
					</Component>
					<Component Id="ThumbExt_vengi" Guid="*" Win64="yes">
						<RegistryKey Root="HKCR" Key=".vengi">
							<RegistryValue Key="ShellEx\{E357FCCD-A995-4576-B01F-234630154E96}" Type="string" Value="{CD1F0EA0-283C-4D90-A41D-DEBD9207D91F}" KeyPath="yes" />
